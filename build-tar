#!/bin/bash
set -euo pipefail

VERSION=$(grep '^version' Cargo.toml | head -1 | sed 's/.*"\(.*\)".*/\1/')
ARCH=$(dpkg --print-architecture 2>/dev/null || uname -m)
case "${ARCH}" in
    amd64|x86_64)  TARGET_ARCH="amd64"  ;;
    arm64|aarch64) TARGET_ARCH="arm64"  ;;
    *)             TARGET_ARCH="${ARCH}" ;;
esac
PKG="ergo-node-rust-${VERSION}-linux-${TARGET_ARCH}"

echo "Building ${PKG}.tar.gz..."

cargo build --release

rm -rf "target/${PKG}"
mkdir -p "target/${PKG}"

cp target/release/ergo-node-rust "target/${PKG}/ergo-node-rust"
strip "target/${PKG}/ergo-node-rust"

cp ergo.toml.example "target/${PKG}/ergo.toml.example"
cp install.sh "target/${PKG}/install.sh"
cp deploy/ergo-node-rust.service "target/${PKG}/ergo-node-rust.service"
cp README.md "target/${PKG}/README.md"

cat > "target/${PKG}/INSTALL.md" <<'EOF'
# ergo-node-rust — manual install

Portable Linux build of `ergo-node-rust`. Run it in place from any
directory, or install system-wide via the bundled systemd unit.

## Quick start (interactive)

```sh
./install.sh
./ergo-node-rust
```

`install.sh` asks a handful of questions (network, state type, data
directory, memory limits) and writes a working `./ergo.toml`. The
binary then picks it up from the current directory.

## Quick start (no setup)

```sh
./ergo-node-rust
```

With no config in any search location, the binary writes a default
`./ergo.toml` (testnet, full archival node) and creates
`./ergo-node-data/` for the chain state, then starts. Edit the
written config later to customize.

## Config search order

When run with no positional argument, the binary searches for a
config in this order, first found wins:

1. `./ergo.toml` (current working directory)
2. `~/.config/ergo-node/ergo.toml` (user-scoped install)
3. `/etc/ergo-node/ergo.toml` (system-wide, via .deb)

An explicit path overrides the search:
`./ergo-node-rust /path/to/my-config.toml`.

## Full option reference

`ergo.toml.example` in this bundle documents every supported option
with its default. Copy or excerpt sections into your `ergo.toml` as
needed.

## System install (systemd)

```sh
sudo install -m 755 ergo-node-rust /usr/bin/ergo-node-rust
sudo install -d /etc/ergo-node /var/lib/ergo-node /var/log/ergo-node
sudo install -m 644 ergo.toml.example /etc/ergo-node/ergo.toml
sudo install -m 644 ergo-node-rust.service /usr/lib/systemd/system/ergo-node-rust.service

# Create the runtime user (skip if it already exists)
sudo adduser --system --group --no-create-home --home /var/lib/ergo-node ergo-node || true
sudo chown -R ergo-node:ergo-node /var/lib/ergo-node /var/log/ergo-node

# Set data_dir = "/var/lib/ergo-node/data" in /etc/ergo-node/ergo.toml
# before starting — the example file's default is `./ergo-node-data`
# which won't work for a systemd-managed install.

sudo systemctl daemon-reload
sudo systemctl enable --now ergo-node-rust
sudo journalctl -u ergo-node-rust -f
```

The bundled systemd unit logs to journald and runs as user
`ergo-node`. See the unit file for the full sandboxing settings.

## See also

The `.deb` package built from the same source automates the systemd
install. Grab the matching `ergo-node-rust_<version>_<arch>.deb`
from the same release if you prefer a packaged install.

For project documentation, see `README.md` in this bundle or
<https://github.com/mwaddip/ergo-node-rust>.
EOF

tar -czf "target/${PKG}.tar.gz" -C target "${PKG}"

rm -rf "target/${PKG}"

echo ""
echo "Built: target/${PKG}.tar.gz"
ls -lh "target/${PKG}.tar.gz"

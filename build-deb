#!/bin/bash
set -euo pipefail

VERSION=$(grep '^version' Cargo.toml | head -1 | sed 's/.*"\(.*\)".*/\1/')
ARCH=$(dpkg --print-architecture 2>/dev/null || echo "amd64")
PKG="ergo-node-rust_${VERSION}_${ARCH}"

echo "Building ergo-node-rust v${VERSION} for ${ARCH}..."

cargo build --release --bin ergo-node-rust --bin sharpen

rm -rf "target/${PKG}"
mkdir -p "target/${PKG}/DEBIAN"
mkdir -p "target/${PKG}/usr/bin"
mkdir -p "target/${PKG}/etc/ergo-node"
mkdir -p "target/${PKG}/usr/lib/systemd/system"

cp target/release/ergo-node-rust "target/${PKG}/usr/bin/"
cp target/release/sharpen "target/${PKG}/usr/bin/"
strip "target/${PKG}/usr/bin/ergo-node-rust"
strip "target/${PKG}/usr/bin/sharpen"

cp deploy/ergo.toml "target/${PKG}/etc/ergo-node/ergo.toml"

cp deploy/ergo-node-rust.service "target/${PKG}/usr/lib/systemd/system/"

mkdir -p "target/${PKG}/etc/fail2ban/filter.d"
mkdir -p "target/${PKG}/etc/fail2ban/jail.d"
cp deploy/fail2ban/ergo-node.conf "target/${PKG}/etc/fail2ban/filter.d/"
cp deploy/fail2ban/ergo-node-jail.conf "target/${PKG}/etc/fail2ban/jail.d/"

mkdir -p "target/${PKG}/usr/share/man/man5"
mkdir -p "target/${PKG}/usr/share/man/man8"
cp man/ergo-node-rust.conf.5.gz "target/${PKG}/usr/share/man/man5/"
cp man/ergo-node-rust.8.gz "target/${PKG}/usr/share/man/man8/"
cp man/sharpen.8.gz "target/${PKG}/usr/share/man/man8/"

# Reference materials shipped under /usr/share/doc/ergo-node-rust/examples/:
# the full annotated config (every supported option, commented with its
# default) and the RRD harness scripts for operator-editable monitoring.
mkdir -p "target/${PKG}/usr/share/doc/ergo-node-rust/examples"
cp ergo.toml.example "target/${PKG}/usr/share/doc/ergo-node-rust/examples/"
cp tools/rrd-create.sh tools/rrd-update.sh tools/rrd-graph.sh tools/rrd-demo-fill.sh \
    "target/${PKG}/usr/share/doc/ergo-node-rust/examples/"

sed "s/^Architecture:.*/Architecture: ${ARCH}/" debian/control > "target/${PKG}/DEBIAN/control"
sed -i "s/^Version:.*/Version: ${VERSION}/" "target/${PKG}/DEBIAN/control"
SIZE=$(du -sk "target/${PKG}" | cut -f1)
echo "Installed-Size: ${SIZE}" >> "target/${PKG}/DEBIAN/control"

cp debian/conffiles "target/${PKG}/DEBIAN/"

for script in preinst postinst prerm postrm; do
    cp "debian/${script}" "target/${PKG}/DEBIAN/"
    chmod 755 "target/${PKG}/DEBIAN/${script}"
done

dpkg-deb --root-owner-group --build "target/${PKG}"

rm -rf "target/${PKG}"

echo ""
echo "Built: target/${PKG}.deb"
ls -lh "target/${PKG}.deb"
